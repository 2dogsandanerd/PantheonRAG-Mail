# ==========================================
# PantheonMail - Environment Configuration
# Kopiere diese Datei nach .env und passe die Werte an
# ==========================================

# === DEV LOGIN (für Entwicklung) ===
# Diese Credentials werden für den Login akzeptiert
DEV_USER=dev
DEV_PASSWORD=dev123
DEV_EMAIL=dev@localhost

# === PFLICHTFELDER ===
# JWT Secret Key — BITTE ÄNDERN!
# Generieren mit: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_-hex_32

# === LLM Konfiguration ===
# Wähle einen Provider: ollama, openai, gemini, anthropic
LLM_PROVIDER=ollama
LLM_MODEL=llama3:latest

# Für OpenAI (falls LLM_PROVIDER=openai):
# OPENAI_API_KEY=sk-...

# Für Google Gemini (falls LLM_PROVIDER=gemini):
# GOOGLE_API_KEY=AIza...

# === Email-Konfiguration ===
EMAIL_PROVIDER=imap
EMAIL_USER=your@example.com
EMAIL_PASSWORD=your-app-password
IMAP_HOST=imap.example.com
IMAP_PORT=993

# === Datenbankpfad ===
DATABASE_URL=sqlite:///./data/app.db

# === Fiat Edition ===
MAIL_EDITION_LEAN=true
EDITION=team

# === Infrastruktur (Docker-Standard, meist nicht ändern) ===
CHROMA_HOST=http://chromadb:8000
CHROMA_PORT=8000
REDIS_HOST=redis
REDIS_PORT=6379
OLLAMA_HOST=http://ollama:11434

# === RAG Einstellungen ===
RERANKER_ENABLED=true
USE_PARENT_RETRIEVER=false
USE_ADVANCED_PIPELINE=false

# === Embedding ===
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest

# === Externes RAG (optional) ===
EXTERNAL_RAG_ENABLED=false
# EXTERNAL_RAG_URL=http://localhost:8080
# EXTERNAL_RAG_API_KEY=
# EXTERNAL_RAG_TIMEOUT=60
